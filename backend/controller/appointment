import Doctor from "../modules/doctor.module.js";
import User from "../modules/user.module.js";
import BookAppointment from "../modules/bookAppointment.module.js";

const timeToMinutes = (timeStr) => {
  const [h, m] = timeStr.split(":").map(Number);
  return h * 60 + m;
};

const intervalScheduling = (appointments) => {
  appointments.sort((a, b) => timeToMinutes(a.end) - timeToMinutes(b.end));

  const selected = [];
  let lastEndTime = 0;

  for (const appt of appointments) {
    const startMin = timeToMinutes(appt.start);
    if (startMin >= lastEndTime) {
      selected.push(appt);
      lastEndTime = timeToMinutes(appt.end);
    }
  }
  return selected;
};

export const bookAppointment = async (req, res) => {
  try {
    const { name, email, date, time, specialty, doctorname } = req.body;

    // Parse time slot "10:00 - 10:30"
    const [newStart, newEnd] = time.split(" - ").map((t) => t.trim());

    // Find patient
    const patient = await User.findOne({ email });
    if (!patient) {
      return res.status(404).json({ message: "Patient not found" });
    }

    // Find doctors with the specialty
    const doctors = await Doctor.find({ specialization: specialty });
    if (!doctors || doctors.length === 0) {
      return res
        .status(404)
        .json({ message: "No doctors found for the specialty" });
    }

    let assignedDoctor;
    if (doctorname) {
      assignedDoctor = doctors.find((doc) => doc.name === doctorname);
      if (!assignedDoctor) {
        return res.status(404).json({ message: "Specified doctor not found" });
      }
    } else {
      // Calculate max experience among doctors to normalize
      const maxExperience = Math.max(
        ...doctors.map((doc) => doc.experience || 0)
      );

      // Build cost matrix (1 patient, many doctors)
      const patientRow = await Promise.all(
        doctors.map(async (doctor) => {
          const existingAppointments = await BookAppointment.find({
            doctorId: doctor._id,
            date: new Date(date),
            status: { $ne: "cancelled" },
          });

          let cost = existingAppointments.length;

          if (doctor.specialization.includes(specialty)) {
            cost -= 1;
          }

          const experienceFactor = doctor.experience
            ? doctor.experience / maxExperience
            : 0;

          cost -= experienceFactor * 2;

          cost = Math.max(0, cost);

          return cost;
        })
      );

      const costMatrix = [patientRow];

      // Run Hungarian Algorithm
      const assignments = hungarianAlgorithm(costMatrix);

      // Pick assigned doctor by index
      const assignedDoctorIndex = assignments[0][1];
      assignedDoctor = doctors[assignedDoctorIndex];
    }

    if (!assignedDoctor) {
      return res.status(404).json({ message: "No suitable doctor found" });
    }

    // Fetch existing appointments for assigned doctor
    const existingAppointments = await BookAppointment.find({
      doctorId: assignedDoctor._id,
      date: new Date(date),
      status: { $ne: "cancelled" },
    });

    // Combine existing and new appointment for interval scheduling
    const allAppointments = existingAppointments.map((appt) => ({
      id: appt._id.toString(),
      start: appt.startTime,
      end: appt.endTime,
      isNew: false,
      apptData: appt,
    }));

    allAppointments.push({
      id: "new",
      start: newStart,
      end: newEnd,
      isNew: true,
    });

    // Apply interval scheduling
    const selectedAppointments = intervalScheduling(allAppointments);
    const newAppointmentSelected = selectedAppointments.some(
      (appt) => appt.isNew
    );

    if (!newAppointmentSelected) {
      return res.status(409).json({
        message: "This time slot conflicts with existing appointments.",
      });
    }

    // Create and save new appointment
    const newAppointment = new BookAppointment({
      doctorName: assignedDoctor.name,
      patientId: patient._id,
      doctorId: assignedDoctor._id,
      date: new Date(date),
      doctorSpecialty: specialty,
      startTime: newStart,
      endTime: newEnd,
      status: "pending",
    });

    await newAppointment.save();

    // Mark doctor's time slot as booked
    const slotIndex = assignedDoctor.timeSlots.findIndex(
      (slot) => slot.start === newStart && slot.end === newEnd
    );

    if (slotIndex !== -1) {
      assignedDoctor.timeSlots[slotIndex].isBooked = true;
      await assignedDoctor.save();
    }

    res.status(201).json({
      message: "Appointment booked successfully",
      appointment: newAppointment,
    });
  } catch (error) {
    console.error("Appointment booking error:", error);
    res
      .status(500)
      .json({ message: "Server error during appointment booking" });
  }
};

export const rescheduleAppointment = async (req, res) => {
  try {
    const { appointmentId, doctorId, newDate, newStart, newEnd } = req.body;

    // Fetch the existing appointment
    const appointment = await BookAppointment.findById(appointmentId);
    if (!appointment) {
      return res.status(404).json({ message: "Appointment not found" });
    }

    // Fetch doctor
    const doctor = await Doctor.findById(doctorId);
    if (!doctor) {
      return res.status(404).json({ message: "Doctor not found" });
    }

    // Get all other appointments for that doctor on new date (exclude current)
    const existingAppointments = await BookAppointment.find({
      doctorId,
      date: new Date(newDate),
      _id: { $ne: appointmentId },
      status: { $ne: "cancelled" },
    });

    // Combine with the rescheduling attempt
    const allAppointments = existingAppointments.map((appt) => ({
      id: appt._id.toString(),
      start: appt.startTime,
      end: appt.endTime,
      isNew: false,
    }));

    allAppointments.push({
      id: "new",
      start: newStart,
      end: newEnd,
      isNew: true,
    });

    // Apply interval scheduling
    const selectedAppointments = intervalScheduling(allAppointments);
    const isNewIncluded = selectedAppointments.some((a) => a.isNew);

    if (!isNewIncluded) {
      return res
        .status(409)
        .json({ message: "New time conflicts with existing appointments." });
    }

    // Update appointment
    appointment.date = new Date(newDate);
    appointment.startTime = newStart;
    appointment.endTime = newEnd;
    appointment.status = "pending";
    await appointment.save();

    res.status(200).json({
      message: "Appointment rescheduled successfully",
      updatedAppointment: appointment,
    });
  } catch (error) {
    console.error("Rescheduling error:", error);
    res.status(500).json({ message: "Server error during rescheduling" });
  }
};


